# Editor configuration, see https://editorconfig.org
root = true

[*]
charset = utf-8
indent_style = tab
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.ts]
quote_type = single

[*.md]
max_line_length = off
trim_trailing_whitespace = false

# Python conventionally uses 4 spaces
[*.py]
indent_style = space
indent_size = 4

# YAML requires spaces
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Makefiles require tabs
[Makefile]
indent_style = tab
