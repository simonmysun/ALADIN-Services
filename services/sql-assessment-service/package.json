	},
	"scripts": {
		"build": "esbuild src/index.ts src/cli/index.ts --bundle --platform=node --target=node20 --format=cjs --outdir=build --sourcemap --inject:./import-meta-url.js --define:import.meta.url=import_meta_url --external:@electric-sql/pglite --external:swagger-ui-dist",
		"build:tsc": "tsc -p tsconfig.json",
		"dev": "npx ts-node src/index.ts",
		"generate-openapi": "npx ts-node src/generate-openapi.ts",
		"lint": "npx eslint ./src",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"cli": "node build/cli/index.js"
	},
	"dependencies": {
		"@electric-sql/pglite": "^0.4.4",
