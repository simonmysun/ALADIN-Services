    "def-4": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Rewriting Rule Processing Config Schema",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rule": {
          "description": "The key of the graph rewriting rule to execute",
          "type": "string"
        },
        "options": {
          "description": "The processing configuration for the rule",
          "type": "object",
          "properties": {
            "mode": {
              "description": "Replace either 'all', only the 'first' or between x and y pattern matches",
              "enum": [
                "all",
                "first",
                "interval"
              ]
            },
            "interval": {
              "type": "object",
              "properties": {
                "min": {
                  "type": "integer"
                },
                "max": {
                  "type": "integer"
                }
              },
              "additionalProperties": false,
              "required": [
                "min",
                "max"
              ]
            },
            "repeat": {
              "anyOf": [
                {
                  "type": "integer"
                },
                {
                  "type": "array",
                  "items": {
                    "type": "integer"
                  },
                  "minItems": 2,
                  "maxItems": 2
                }
              ]
            }
          },
          "additionalProperties": false,
          "if": {
            "properties": {
              "mode": {
                "enum": [
                  "interval"
                ]
              }
            }
          },
          "then": {
            "required": [
              "interval"
            ]
          }
        }
      },
      "required": [
        "rule",
        "options"
      ]
    },
